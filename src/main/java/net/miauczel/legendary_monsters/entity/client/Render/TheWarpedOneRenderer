public class TheWarpedOneRenderer extends MobRenderer<TheWarpedOneEntity,TheWarpedOneModel<TheWarpedOneEntity>> {
    public TheWarpedOneRenderer(EntityRendererProvider.Context pContext) {
        super(pContext, new TheWarpedOneModel<>(pContext.bakeLayer(ModModelLayers.WARPED_ONE_LAYER)), 1f);
    }

    @Override
    public ResourceLocation getTextureLocation(TheWarpedOneEntity pEntity) {

        return new ResourceLocation(LegendaryMonsters.MOD_ID, "textures/entity/the_warped_one/the_warped_one.png")  ;
    }

    @Override
    public void render(TheWarpedOneEntity pEntity, float pEntityYaw, float pPartialTicks, PoseStack pMatrixStack,
                       MultiBufferSource pBuffer, int pPackedLight) {

pMatrixStack.scale(0.8f,0.8f,0.8f);

        super.render(pEntity, pEntityYaw, pPartialTicks, pMatrixStack, pBuffer, pPackedLight);
    }
}
