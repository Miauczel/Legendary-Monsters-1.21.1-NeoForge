	@Override
	public void setupAnim(T entity, float limbSwing, float limbSwingAmount, float ageInTicks, float netHeadYaw, float headPitch) {
		Entity entityCamera = Minecraft.getInstance().getCameraEntity();

		this.eye_mid.visible = true;
		if (entityCamera != null) {
			Vec3 vec3 = entityCamera.getEyePosition(0.0F);
			Vec3 vec31 = entity.getEyePosition(0.0F);
			double d0 = vec3.y - vec31.y;
			if (d0 > 0.0D) {
				this.eye_mid.y = 0.0F;
			} else {
				this.eye_mid.y = 1.0F;
			}

			Vec3 vec32 = entity.getViewVector(0.0F);
			vec32 = new Vec3(vec32.x, 0.0D, vec32.z);
			Vec3 vec33 = (new Vec3(vec31.x - vec3.x, 0.0D, vec31.z - vec3.z)).normalize().yRot(((float)Math.PI / 2F));
			double d1 = vec32.dot(vec33);
			this.eye_mid.x = Mth.sqrt((float)Math.abs(d1)) * 2.0F * (float)Math.signum(d1);
		}
		this.root().getAllParts().forEach(ModelPart::resetPose);
		this.applyHeadRotation( entity, netHeadYaw, headPitch, ageInTicks);
		this.animate(entity.getAnimationState("idle"), TheWarpedOneAnimations.idle, ageInTicks, 1.0F);
		this.animate(entity.getAnimationState("sleep"), TheWarpedOneAnimations.sleep, ageInTicks, 1.0F);

		this.animate(entity.getAnimationState("death"), TheWarpedOneAnimations.death, ageInTicks, 1.0F);

		this.animate(entity.getAnimationState("spinsmash"), TheWarpedOneAnimations.spinsmashSmoother, ageInTicks, 1.0F);
		this.animate(entity.getAnimationState("leftspinsmash"), TheWarpedOneAnimations.leftspinSmash, ageInTicks, 1.0F);

		this.animate(entity.getAnimationState("roar"), TheWarpedOneAnimations.roar2, ageInTicks, 1.0F);
		this.animate(entity.getAnimationState("fall"), TheWarpedOneAnimations.fall, ageInTicks, 1.0F);
		this.animate(entity.getAnimationState("land"), TheWarpedOneAnimations.land, ageInTicks, 1.0F);
		this.animate(entity.getAnimationState("teleportland"), TheWarpedOneAnimations.landTeleport, ageInTicks, 1.0F);


		this.animate(entity.getAnimationState("uppercutpre"), TheWarpedOneAnimations.teleportUpperCutPre, ageInTicks, 1.0F);
		this.animate(entity.getAnimationState("uppercutfail"), TheWarpedOneAnimations.teleportUppercutFail, ageInTicks, 1.0F);
		this.animate(entity.getAnimationState("uppercutsuccess"), TheWarpedOneAnimations.teleportUppercutSuccess, ageInTicks, 1.0F);
		this.animate(entity.getAnimationState("teleportuppercut"), TheWarpedOneAnimations.teleportUppercutSlower, ageInTicks, 1.0F);

		//this.animateWalk(ChoruslingAnimations.WALK2, limbSwing, limbSwingAmount, 1.5f, 2.5f);
void_axe2.visible = false;


	}



	private void applyHeadRotation(TheWarpedOneEntity pEntity, float pNetHeadYaw, float pHeadPitch, float pAgeInTicks) {
		pNetHeadYaw = Mth.clamp(pNetHeadYaw, -30.0F, 30.0F);
		pHeadPitch = Mth.clamp(pHeadPitch, -25.0F, 25.0F);
		this.the_eye.yRot = pNetHeadYaw * ((float)Math.PI / 180F);
		this.the_eye.xRot = pHeadPitch * ((float)Math.PI / 180F);
	}




